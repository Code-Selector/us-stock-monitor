# us-stock-monitor 环境变量模板（请复制为 .env.local 并填入真实值）
# 不要将包含真实密钥的文件提交到 Git！

# 钉钉机器人配置
US_STOCK_DINGTALK_TOKEN=your_token_here
US_STOCK_DINGTALK_SECRET=your_secret_here
US_STOCK_DINGTALK_USER_ID=<you need @ group user's userId>

# 百度翻译 API
BAIDU_TRANSLATE_HOST=https://fanyi-api.baidu.com/api/trans/vip/translate
BAIDU_TRANSLATE_APPID=your_app_id_here
BAIDU_TRANSLATE_SECURITYKEY=your_security_key_here

# 数据库密码（如果不用环境变量，也可以放这里）
US_STOCK_DB_PASSWORD=your_password_here
